# ── Telethon userbot (читает сообщения из групп) ──────────────────
# Получить на https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here
# Телефон userbot-аккаунта в международном формате
PHONE=+1234567890

# ── Tradium Bot (aiogram, шлёт алерты о Tradium-сигналах) ─────────
# Создать в @BotFather
BOT_TOKEN=1234567890:AAE...
# ID твоего чата куда слать алерты (узнать у @userinfobot)
ADMIN_CHAT_ID=123456789

# ── Источник Tradium-сигналов ─────────────────────────────────────
# ID супергруппы Telegram -100...
SOURCE_GROUP_ID=-1002423680272
# Сколько секунд userbot ждёт график после текста сигнала
CHART_WAIT_SECONDS=60

# ── Anthropic Claude (AI анализ графиков и quality score) ────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Директория для скачанных графиков ────────────────────────────
CHARTS_DIR=./charts

# ── Admin Panel auth ─────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password
# Случайная строка 32+ символов для HMAC session cookie
SECRET_KEY=change_me_to_random_string_32_chars_minimum

# ── MongoDB Atlas (или свой Mongo) ──────────────────────────────
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0
MONGO_DB=tradium

# ── Второй бот: Cryptovizor ─────────────────────────────────────
BOT2_NAME=cryptovizor
BOT2_LABEL=Cryptovizor
# Токен бота для Cryptovizor-алертов
BOT2_BOT_TOKEN=1234567890:AAE...
# Имя диалога Cryptovizor (userbot резолвит автоматически)
BOT2_SOURCE_GROUP=TRENDS Cryptovizor
